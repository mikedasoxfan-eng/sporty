    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "data:download": "tsx scripts/download.ts",
    "data:ingest": "tsx scripts/ingest.ts",
